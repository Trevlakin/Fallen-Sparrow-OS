# ─────────────────────────────────────────────────────────────
# FALLEN SPARROW — ENVIRONMENT VARIABLES
# Copy to `.env`, fill in real values. NEVER commit `.env`.
# ALL access goes through config/env.ts (Zod-validated, fails fast at boot).
# Never read process.env.X anywhere else in the code.
# ─────────────────────────────────────────────────────────────

# ─── CORE ────────────────────────────────────────────────────
NODE_ENV=development                      # development | production
PORT=3000
APP_BASE_URL=http://localhost:3000        # prod: https://api.fallensparrowos.com
DEFAULT_TIMEZONE=America/New_York          # Kissimmee, FL is Eastern. Drives 6am briefing + date handling.

# ─── DATABASE (Railway PostgreSQL) ───────────────── [Sprint 1]
DATABASE_URL=postgresql://user:pass@host:5432/fallen_sparrow

# ─── AUTH ─────────────────────────────────────────── [Sprint 1]
JWT_SECRET=                                # long random string (openssl rand -hex 32)
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ─── ANTHROPIC (Claude) ───────────────────────────── [Sprint 4]
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6          # PINNED. Do not change to a GPT/OpenAI model.

# ─── RESEND (email + Porter CSV inbound) ──────────── [Sprint 2 + 7]
RESEND_API_KEY=
RESEND_FROM_EMAIL=briefings@fallensparrow.example     # verified sending domain
PORTER_INBOUND_EMAIL=porter-imports@inbound.fallensparrow.example  # Zapier emails CSVs here
RESEND_INBOUND_WEBHOOK_SECRET=             # verify inbound webhook signature

# ─── TWILIO (SMS — customer nudges, reminders) ────── [Sprint 7]
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=                       # +1XXXXXXXXXX

# ─── CLOUDFLARE R2 (receipt photos, exports) ──────── [Sprint 4]
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=fallen-sparrow-files
R2_PUBLIC_URL=                             # public/CDN base URL for stored files

# ─── QUICKBOOKS ONLINE ────────────────────────────── [Sprint 8R]
# Developer (Trevor) creates the app at developer.intuit.com → Client ID + Secret.
# Legion's QB admin does the one-time OAuth consent in production.
# REALM_ID is captured during OAuth consent; leave blank until then.
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:3000/api/quickbooks/callback
QBO_ENVIRONMENT=sandbox                    # sandbox | production
QBO_REALM_ID=                              # optional fallback; normally set during OAuth
WEB_APP_URL=http://localhost:5173          # prod: https://fallensparrowos.com
WEB_APP_ALLOWED_ORIGINS=                   # prod: https://www.fallensparrowos.com

# ─── DEPLOY (local only — never commit real tokens) ───────────
# RAILWAY_TOKEN=                           # https://railway.com/account/tokens
# VERCEL_TOKEN=                            # https://vercel.com/account/tokens

# ─── SENTRY (error monitoring) ────────────────────── [Sprint 1+]
SENTRY_DSN=

# ─── PORTER API (UPGRADE PATH — UNCONFIRMED, open item Q1d) ──
# Leave blank. Primary path is Zapier CSV via Resend inbound (above).
# Only fill these if/when Porter confirms an API. Field names are NOT yet known —
# all CSV→normalized mapping lives in one mapPorterRow() function.
# PORTER_API_KEY=
# PORTER_API_BASE_URL=

# ─── JOBS / SCHEDULING ───────────────────────────────────────
BRIEFING_RECIPIENT_EMAIL=                   # Legion's inbox for automated briefings (required for cron delivery)
BRIEFING_SEND_HOUR=6                       # local hour (DEFAULT_TIMEZONE) for the daily briefing
WEEKLY_REPORT_DAY=5                        # 5 = Friday
WEEKLY_REPORT_HOUR=17                      # 5pm

# ─── JARVIS TTS (optional ElevenLabs upgrade) ──────────────── [Sprint 8G]
# Leave blank to use browser speechSynthesis fallback.
VITE_ELEVENLABS_API_KEY=
VITE_ELEVENLABS_VOICE_ID=
