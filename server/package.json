{
  "name": "@fallen-sparrow/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node dist/db/migrate.js",
    "db:migrate:dev": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:local": "tsx scripts/setup-local-db.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.0",
    "@aws-sdk/client-s3": "^3.1057.0",
    "@fallen-sparrow/shared": "workspace:*",
    "@sentry/node": "^9.30.0",
    "bcrypt": "^6.0.0",
    "busboy": "^1.6.0",
    "csv-parse": "^5.6.0",
    "drizzle-orm": "^0.44.2",
    "express": "^5.1.0",
    "intuit-oauth": "^4.2.3",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "node-quickbooks": "^2.0.50",
    "pg": "^8.16.0",
    "resend": "^6.12.4",
    "twilio": "^6.0.2",
    "winston": "^3.17.0",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/busboy": "^1.5.4",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.29",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.15.2",
    "@types/supertest": "^6.0.3",
    "dotenv": "^16.5.0",
    "drizzle-kit": "^0.31.1",
    "embedded-postgres": "18.3.0-beta.17",
    "supertest": "^7.1.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
