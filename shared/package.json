{
  "name": "@fallen-sparrow/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "import": "./dist/constants.js"
    },
    "./serviceTypes": {
      "types": "./dist/serviceTypes.d.ts",
      "import": "./dist/serviceTypes.js"
    },
    "./dates": {
      "types": "./dist/dates.d.ts",
      "import": "./dist/dates.js"
    },
    "./porterCsv": {
      "types": "./dist/porterCsv.d.ts",
      "import": "./dist/porterCsv.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.2"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
